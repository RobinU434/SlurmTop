Bootstrap: docker
From: debian:10

%labels
    Author RobinU434
    Description "Debian 10 (glibc 2.28) build environment for SlurmTop"
    Version "0.1"

%help
    This image installs the Rust toolchain and build essentials so that SlurmTop can
    be compiled inside a reproducible container on the cluster. It also ships a
    Python virtual environment with maturin so you can build and install the PyO3
    bindings. No Slurm CLI binaries are included—the container is strictly for
    compiling artifacts.

%environment
    export CARGO_HOME="/opt/rust/.cargo"
    export RUSTUP_HOME="/opt/rust/.rustup"
    export SLURMTOP_VENV="/opt/venvs/slurmtop"
    export PATH="$SLURMTOP_VENV/bin:$CARGO_HOME/bin:$PATH"

%post
    set -euo
    sed -i 's|deb.debian.org/debian|archive.debian.org/debian|g' /etc/apt/sources.list
    sed -i 's|security.debian.org/debian-security|archive.debian.org/debian-security|g' /etc/apt/sources.list
    echo 'Acquire::Check-Valid-Until "false";' > /etc/apt/apt.conf.d/99no-check-valid-until
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        git \
        pkg-config \
        libssl-dev \
        libclang-dev \
        libzstd-dev \
        zlib1g-dev \
        python3 \
        python3-venv \
    python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install rustup + cargo (minimal profile)
    export CARGO_HOME="/opt/rust/.cargo"
    export RUSTUP_HOME="/opt/rust/.rustup"
    mkdir -p "$CARGO_HOME" "$RUSTUP_HOME"
    curl --proto '=https' --tlsv1.2 https://sh.rustup.rs -sSf | \
        sh -s -- -y --no-modify-path --default-toolchain stable --profile minimal

    # Pre-cache commonly used targets
    "$CARGO_HOME/bin/rustup" component add rustfmt clippy

    # Python virtual environment for maturin/PyO3 builds
    export SLURMTOP_VENV="/opt/venvs/slurmtop"
    mkdir -p /opt/venvs
    python3 -m venv "$SLURMTOP_VENV"
    . "$SLURMTOP_VENV/bin/activate"
    pip install --upgrade pip setuptools wheel
    pip install maturin

    cat <<'EOF' >/usr/local/bin/slurmtop-python-build
#!/bin/bash
set -euo pipefail
if [ -d /workspace ]; then
    cd /workspace
fi
if [ ! -f Cargo.toml ]; then
    echo "[slurmtop-python-build] Expecting Cargo.toml in current directory" >&2
    exit 1
fi
source "${SLURMTOP_VENV:-/opt/venvs/slurmtop}/bin/activate"
maturin develop --features python "$@"
EOF
    chmod +x /usr/local/bin/slurmtop-python-build

    cat <<'EOF' >/usr/local/bin/slurmtop-python-run
#!/bin/bash
set -euo pipefail
slurmtop-python-build "$@"
    exec python3 -m slurmtop
EOF
    chmod +x /usr/local/bin/slurmtop-python-run

%runscript
    # Default action builds the project inside /workspace (bind-mounted)
    if [ -d /workspace ]; then
        cd /workspace
    fi
    exec "$CARGO_HOME/bin/cargo" "$@"
